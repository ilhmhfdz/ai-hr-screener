# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# MongoDB Atlas
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/hr_screener?retryWrites=true&w=majority
MONGODB_DB_NAME=hr_screener

# JWT Auth
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# App
MAX_CVS_PER_BATCH=25
